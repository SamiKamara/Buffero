<Window x:Class="Buffero.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Buffero"
        Width="820"
        Height="700"
        MinWidth="820"
        MinHeight="640"
        Icon="Assets/buffero.ico"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="AdvancedOnlyStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAdvancedMode}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DefaultOnlyStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAdvancedMode}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding MainContentColumnWidth}" />
                <ColumnDefinition Width="{Binding SidePanelColumnWidth}" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="26"
                               FontWeight="SemiBold"
                               Text="Buffero" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#555"
                               Text="Windows replay-buffer app with a native capture path by default and ffmpeg kept as a fallback option." />
                </StackPanel>

                <Button Grid.Column="1"
                        Height="36"
                        Padding="16,0"
                        Margin="20,0,0,0"
                        VerticalAlignment="Center"
                        Click="ToggleUiMode_Click"
                        Content="{Binding UiModeToggleButtonText}" />
            </Grid>

            <Border Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Padding="18"
                    Margin="0,0,0,16"
                    Background="#F6F7F8"
                    BorderBrush="#D5D9DE"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="14"
                                   FontWeight="Bold"
                                   Text="{Binding StateName}" />
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Text="{Binding StatusMessage}" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#555"
                                   Text="{Binding StatusDetails}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="16,0,0,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Height="36"
                                Padding="14,0"
                                Margin="0,0,8,0"
                                IsEnabled="{Binding ReplayBufferEnabled}"
                                Click="StartBuffering_Click"
                                Content="Start Buffering" />
                        <Button Height="36"
                                Padding="14,0"
                                Margin="0,0,8,0"
                                IsEnabled="{Binding ReplayBufferEnabled}"
                                Click="StopBuffering_Click"
                                Content="Stop Buffering" />
                        <Button Height="36"
                                Padding="14,0"
                                IsEnabled="{Binding ReplayBufferEnabled}"
                                Click="SaveReplay_Click"
                                Content="Save Replay" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,0">
                <GroupBox Margin="0,0,0,16" Header="Capture">
                    <StackPanel Margin="12">
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock FontWeight="SemiBold" Text="Save Directory" />
                            <DockPanel Margin="0,6,0,0">
                                <Button Width="74"
                                        DockPanel.Dock="Right"
                                        Click="BrowseSaveFolder_Click"
                                        Content="Browse" />
                                <TextBox Margin="0,0,10,0"
                                         Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12"
                                    Style="{StaticResource AdvancedOnlyStyle}">
                            <TextBlock FontWeight="SemiBold" Text="Capture Backend" />
                            <ComboBox Margin="0,6,0,0"
                                      ItemsSource="{Binding SupportedCaptureBackends}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding CaptureBackend}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12"
                                    Style="{StaticResource AdvancedOnlyStyle}">
                            <TextBlock FontWeight="SemiBold" Text="ffmpeg Path" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#666"
                                       Text="Used when the ffmpeg backend is selected or when native capture/export falls back." />
                            <TextBox Margin="0,6,0,0"
                                     Text="{Binding FfmpegPath, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <UniformGrid Columns="2"
                                     Margin="0,0,0,12"
                                     Style="{StaticResource DefaultOnlyStyle}">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding ReplaySecondsHeader}" />
                                <TextBox Margin="0,6,0,0"
                                         Text="{Binding BufferSeconds, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock FontWeight="SemiBold" Text="FPS" />
                                <TextBox Margin="0,6,0,0"
                                         Text="{Binding Fps, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>

                        <UniformGrid Columns="3"
                                     Margin="0,0,0,12"
                                     Style="{StaticResource AdvancedOnlyStyle}">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding ReplaySecondsHeader}" />
                                <TextBox Margin="0,6,0,0"
                                         Text="{Binding BufferSeconds, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock FontWeight="SemiBold" Text="Segment Seconds" />
                                <TextBox Margin="0,6,0,0"
                                         Text="{Binding SegmentSeconds, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock FontWeight="SemiBold" Text="FPS" />
                                <TextBox Margin="0,6,0,0"
                                         Text="{Binding Fps, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>

                        <Grid Margin="0,0,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.ColumnSpan="2"
                                       Foreground="#666"
                                       TextWrapping="Wrap"
                                       Text="{Binding QualityEstimateSummary}" />

                            <StackPanel Grid.Row="1" Margin="0,10,12,0">
                                <TextBlock FontWeight="SemiBold" Text="Quality CRF" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#666"
                                           Text="{Binding CrfFieldStatus}" />
                                <TextBox Width="96"
                                         Margin="0,6,0,0"
                                         HorizontalAlignment="Left"
                                         IsEnabled="{Binding IsCrfQualityActive}"
                                         Text="{Binding QualityCrf, UpdateSourceTrigger=PropertyChanged}" />
                                <Slider Margin="0,10,0,0"
                                        Minimum="18"
                                        Maximum="35"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding QualityCrf, UpdateSourceTrigger=PropertyChanged}">
                                    <Slider.Style>
                                        <Style TargetType="Slider">
                                            <Setter Property="Opacity" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCrfQualityActive}" Value="False">
                                                    <Setter Property="Opacity" Value="0.65" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Slider.Style>
                                </Slider>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,10,0,0">
                                <TextBlock FontWeight="SemiBold" Text="Quality Mb/s" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#666"
                                           Text="{Binding BitrateFieldStatus}" />
                                <TextBox Width="96"
                                         Margin="0,6,0,0"
                                         HorizontalAlignment="Left"
                                         IsEnabled="{Binding IsBitrateQualityActive}"
                                         Text="{Binding QualityBitrateMbps, UpdateSourceTrigger=PropertyChanged}" />
                                <Slider Margin="0,10,0,0"
                                        Minimum="2"
                                        Maximum="120"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding QualityBitrateMbps, UpdateSourceTrigger=PropertyChanged}">
                                    <Slider.Style>
                                        <Style TargetType="Slider">
                                            <Setter Property="Opacity" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBitrateQualityActive}" Value="False">
                                                    <Setter Property="Opacity" Value="0.65" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Slider.Style>
                                </Slider>
                            </StackPanel>
                        </Grid>

                        <UniformGrid Columns="4"
                                     Style="{StaticResource AdvancedOnlyStyle}">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock FontWeight="SemiBold" Text="Clip Pattern" />
                                <TextBox Margin="0,6,0,0"
                                         Text="{Binding ClipFilePattern, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock FontWeight="SemiBold" Text="Capture Mode" />
                                <ComboBox Margin="0,6,0,0"
                                          ItemsSource="{Binding SupportedCaptureModes}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding CaptureMode}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock FontWeight="SemiBold" Text="Capture Resolution" />
                                <ComboBox Margin="0,6,0,0"
                                          ItemsSource="{Binding SupportedResolutionModes}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding OutputResolution}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Max Temp Storage (GB)" />
                                <TextBox Margin="0,6,0,0"
                                         Text="{Binding MaxTempStorageGb, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Margin="0,0,0,16"
                          Header="Detection"
                          Style="{StaticResource AdvancedOnlyStyle}">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <CheckBox Content="Enable replay buffer"
                                  IsChecked="{Binding ReplayBufferEnabled}" />
                        <CheckBox Grid.Row="1"
                                  Margin="0,8,0,0"
                                  Content="Start Buffero automatically when Windows starts"
                                  IsChecked="{Binding StartWithWindows}" />
                        <CheckBox Grid.Row="2"
                                  Margin="0,8,0,0"
                                  Content="Enable auto-start when a configured game is found"
                                  IsEnabled="{Binding IsAutomaticBufferActivationMode}"
                                  IsChecked="{Binding AutoStartEnabled}" />
                        <CheckBox Grid.Row="3"
                                  Margin="0,8,0,0"
                                  Content="Require the configured game to be the foreground window"
                                  IsChecked="{Binding RequireForegroundWindow}" />
                        <CheckBox Grid.Row="4"
                                  Margin="0,8,0,0"
                                  Content="Show replay save overlays and tray notifications"
                                  IsChecked="{Binding NotificationsEnabled}" />
                        <StackPanel Grid.Row="5"
                                    Margin="0,12,0,0"
                                    Style="{StaticResource AdvancedOnlyStyle}">
                            <DockPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Text="Buffering Widget Opacity" />
                                <TextBlock DockPanel.Dock="Right"
                                           Foreground="#666"
                                           Text="{Binding BufferingWidgetOpacityDisplay}" />
                            </DockPanel>
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#666"
                                       Text="Controls the bottom-right in-game buffering widget opacity." />
                            <Slider Margin="0,8,0,0"
                                    Minimum="0.1"
                                    Maximum="1"
                                    TickFrequency="0.05"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding BufferingWidgetOpacity, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Row="6" Margin="0,12,0,0">
                            <TextBlock FontWeight="SemiBold" Text="Configured Game Executables" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#666"
                                       Text="One executable per line. Example: valorant.exe or cs2" />
                            <TextBox Height="120"
                                     Margin="0,8,0,0"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding AllowedExecutablesText, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Hotkey Settings">
                    <StackPanel Margin="12">
                        <TextBlock FontWeight="SemiBold" Text="Buffer Activation Mode" />
                        <ComboBox Margin="0,6,0,0"
                                  ItemsSource="{Binding SupportedBufferActivationModes}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding BufferActivationMode}" />

                        <TextBlock Margin="0,14,0,0"
                                   FontWeight="SemiBold"
                                   Text="Save Replay Hotkey" />
                        <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                            <CheckBox Margin="0,0,16,0"
                                      Content="Ctrl"
                                      IsChecked="{Binding HotkeyCtrl}" />
                            <CheckBox Margin="0,0,16,0"
                                      Content="Alt"
                                      IsChecked="{Binding HotkeyAlt}" />
                            <CheckBox Margin="0,0,16,0"
                                      Content="Shift"
                                      IsChecked="{Binding HotkeyShift}" />
                            <ComboBox Width="110"
                                      ItemsSource="{Binding SupportedHotkeyKeys}"
                                      SelectedItem="{Binding SelectedHotkeyKey}" />
                        </StackPanel>
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#555"
                                   Text="{Binding HotkeyPreview}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#555"
                                   TextWrapping="Wrap"
                                   Text="{Binding HotkeyStatus}" />

                        <TextBlock Margin="0,14,0,0"
                                   FontWeight="SemiBold"
                                   Text="Buffer Toggle Hotkey" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#666"
                                   TextWrapping="Wrap"
                                   Text="Used when buffer activation mode is set to Toggle buffering with a hotkey." />
                        <StackPanel Margin="0,6,0,0"
                                    Orientation="Horizontal"
                                    IsEnabled="{Binding IsHotkeyBufferActivationMode}">
                            <CheckBox Margin="0,0,16,0"
                                      Content="Ctrl"
                                      IsChecked="{Binding ToggleHotkeyCtrl}" />
                            <CheckBox Margin="0,0,16,0"
                                      Content="Alt"
                                      IsChecked="{Binding ToggleHotkeyAlt}" />
                            <CheckBox Margin="0,0,16,0"
                                      Content="Shift"
                                      IsChecked="{Binding ToggleHotkeyShift}" />
                            <ComboBox Width="110"
                                      ItemsSource="{Binding SupportedHotkeyKeys}"
                                      SelectedItem="{Binding SelectedToggleHotkeyKey}" />
                        </StackPanel>
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#555"
                                   Text="{Binding ToggleHotkeyPreview}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#555"
                                   TextWrapping="Wrap"
                                   Text="{Binding ToggleHotkeyStatus}" />
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Grid.Column="1"
                        MaxWidth="{Binding SidePanelMaxWidth}">
                <GroupBox Margin="0,0,0,16" Header="Actions">
                    <Grid Margin="12">
                        <WrapPanel Style="{StaticResource AdvancedOnlyStyle}">
                            <Button Width="150"
                                    Height="34"
                                    Margin="0,0,10,10"
                                    Click="ApplySettings_Click"
                                    Content="Save Settings" />
                            <Button Width="150"
                                    Height="34"
                                    Margin="0,0,10,10"
                                    Click="OpenClipsFolder_Click"
                                    Content="Open Clips Folder" />
                            <Button Width="150"
                                    Height="34"
                                    Margin="0,0,10,10"
                                    Click="OpenLogsFolder_Click"
                                    Content="Open Logs Folder" />
                            <Button Width="150"
                                    Height="34"
                                    Margin="0,0,10,10"
                                    Click="HideToTray_Click"
                                    Content="Hide To Tray" />
                        </WrapPanel>

                        <StackPanel Style="{StaticResource DefaultOnlyStyle}">
                            <Button Width="148"
                                    Height="34"
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="Left"
                                    Click="ApplySettings_Click"
                                    Content="Save Settings" />
                            <Button Width="148"
                                    Height="34"
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="Left"
                                    Click="OpenClipsFolder_Click"
                                    Content="Open Clips Folder" />
                            <Button Width="148"
                                    Height="34"
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="Left"
                                    Click="OpenLogsFolder_Click"
                                    Content="Open Logs Folder" />
                            <Button Width="148"
                                    Height="34"
                                    HorizontalAlignment="Left"
                                    Click="HideToTray_Click"
                                    Content="Hide To Tray" />
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Margin="0,0,0,16"
                          Header="Persistent Window Sizes"
                          Style="{StaticResource AdvancedOnlyStyle}">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="3"
                                   Margin="0,0,0,12"
                                   Foreground="#666"
                                   TextWrapping="Wrap"
                                   Text="Saved on Save Settings. These sizes are applied when Buffero opens and when you switch UI modes." />

                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,0,12,8"
                                   FontWeight="SemiBold"
                                   Text="Width" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="2"
                                   Margin="0,0,0,8"
                                   FontWeight="SemiBold"
                                   Text="Height" />

                        <TextBlock Grid.Row="2"
                                   VerticalAlignment="Center"
                                   Text="Default mode" />
                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Width="96"
                                 Margin="12,0,12,8"
                                 Text="{Binding DefaultModeWindowWidth, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="2"
                                 Grid.Column="2"
                                 Width="96"
                                 Margin="0,0,0,8"
                                 Text="{Binding DefaultModeWindowHeight, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="3"
                                   VerticalAlignment="Center"
                                   Text="Advanced mode" />
                        <TextBox Grid.Row="3"
                                 Grid.Column="1"
                                 Width="96"
                                 Margin="12,0,12,0"
                                 Text="{Binding AdvancedModeWindowWidth, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Grid.Row="3"
                                 Grid.Column="2"
                                 Width="96"
                                 Text="{Binding AdvancedModeWindowHeight, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </GroupBox>

                <GroupBox Margin="0,0,0,16"
                          Header="Diagnostics"
                          Style="{StaticResource AdvancedOnlyStyle}">
                    <TextBox Margin="12"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding DiagnosticsText, Mode=OneWay}" />
                </GroupBox>

                <GroupBox Header="Recent Log"
                          Style="{StaticResource AdvancedOnlyStyle}">
                    <Grid Margin="12">
                        <ListBox Height="330"
                                 ItemsSource="{Binding RecentLogLines}" />
                    </Grid>
                </GroupBox>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
